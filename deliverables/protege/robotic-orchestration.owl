@prefix : <https://www.cs7820-robo-orchestration.org/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix robo-ont: <https://www.cs7820-robo-orchestration.org/ontology/> .
@base <https://www.cs7820-robo-orchestration.org/ontology/> .

<https://www.cs7820-robo-orchestration.org/ontology/> rdf:type owl:Ontology ;
                                                       owl:imports <http://daselab.org/ContextualizedWinstonPartWhole> .

#################################################################
#    Object Properties
#################################################################

###  http://daselab.org/ContextualizedWinstonPartWhole#hasWhole
<http://daselab.org/ContextualizedWinstonPartWhole#hasWhole> rdfs:range robo-ont:SpatialThing .


###  http://daselab.org/ContextualizedWinstonPartWhole#isPartOf
<http://daselab.org/ContextualizedWinstonPartWhole#isPartOf> rdfs:domain robo-ont:SpatialThing .


###  http://daselab.org/ContextualizedWinstonPartWhole#part-of
<http://daselab.org/ContextualizedWinstonPartWhole#part-of> rdfs:domain robo-ont:SpatialThing ;
                                                            rdfs:range robo-ont:SpatialThing .


###  http://daselab.org/ContextualizedWinstonPartWhole#spatially-located-in
<http://daselab.org/ContextualizedWinstonPartWhole#spatially-located-in> rdfs:domain robo-ont:SpatialThing ;
                                                                         rdfs:range robo-ont:SpatialThing .


###  https://www.cs7820-robo-orchestration.org/ontology/assimilatesArchetype
robo-ont:assimilatesArchetype rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/assimilatesRoleCategory
robo-ont:assimilatesRoleCategory rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/assumesRole
robo-ont:assumesRole rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/belongsToCategory
robo-ont:belongsToCategory rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/dependsOnTask
robo-ont:dependsOnTask rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/enabledBy
robo-ont:enabledBy rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/enabledBySpatialThing
robo-ont:enabledBySpatialThing rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf owl:topObjectProperty ;
                               rdfs:domain [ rdf:type owl:Restriction ;
                                             owl:onProperty robo-ont:enabledBySpatialThing ;
                                             owl:someValuesFrom robo-ont:SpatialThing
                                           ] .


###  https://www.cs7820-robo-orchestration.org/ontology/enablesAction
robo-ont:enablesAction rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/enablesCapability
robo-ont:enablesCapability rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/fulfillsArchetype
robo-ont:fulfillsArchetype rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasCapability
robo-ont:hasCapability rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasCategorizationType
robo-ont:hasCategorizationType rdf:type owl:ObjectProperty ;
                               rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasDeadline
robo-ont:hasDeadline rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasDescription
robo-ont:hasDescription rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasFileLocation
robo-ont:hasFileLocation rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasGeometry
robo-ont:hasGeometry rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasIdentifier
robo-ont:hasIdentifier rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty ;
                       rdfs:range robo-ont:Identifier .


###  https://www.cs7820-robo-orchestration.org/ontology/hasNextTask
robo-ont:hasNextTask rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasOperationalExtent
robo-ont:hasOperationalExtent rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasSpatioTemporalExtent
robo-ont:hasSpatioTemporalExtent rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasSpatiotemporalExtent
robo-ont:hasSpatiotemporalExtent rdf:type owl:ObjectProperty ;
                                 rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasSpec
robo-ont:hasSpec rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasSpecKind
robo-ont:hasSpecKind rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasState
robo-ont:hasState rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasSubGoal
robo-ont:hasSubGoal rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasSuccessState
robo-ont:hasSuccessState rdf:type owl:ObjectProperty ;
                         rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasTask
robo-ont:hasTask rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasTemporalExtent
robo-ont:hasTemporalExtent rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasThreshold
robo-ont:hasThreshold rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasUnit
robo-ont:hasUnit rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasValue
robo-ont:hasValue rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/isWithinBounds
robo-ont:isWithinBounds rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf owl:topObjectProperty ;
                        rdfs:range robo-ont:SpatialExtent .


###  https://www.cs7820-robo-orchestration.org/ontology/metadataFormat
robo-ont:metadataFormat rdf:type owl:ObjectProperty ;
                        rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/providesRole
robo-ont:providesRole rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/requiresArchetype
robo-ont:requiresArchetype rdf:type owl:ObjectProperty ;
                           rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/requiresCapability
robo-ont:requiresCapability rdf:type owl:ObjectProperty ;
                            rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/requiresSpatialThing
robo-ont:requiresSpatialThing rdf:type owl:ObjectProperty ;
                              rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/subclassOf
robo-ont:subclassOf rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf owl:topObjectProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/unitAsString
robo-ont:unitAsString rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf owl:topObjectProperty .


#################################################################
#    Data properties
#################################################################

###  https://www.cs7820-robo-orchestration.org/ontology/asString
robo-ont:asString rdf:type owl:DatatypeProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/fileLocationAsString
robo-ont:fileLocationAsString rdf:type owl:DatatypeProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasDescription
robo-ont:hasDescription rdf:type owl:DatatypeProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasInstructionalText
robo-ont:hasInstructionalText rdf:type owl:DatatypeProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/hasValue
robo-ont:hasValue rdf:type owl:DatatypeProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/identifierAsText
robo-ont:identifierAsText rdf:type owl:DatatypeProperty ;
                          rdfs:subPropertyOf owl:topDataProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/metadataFormatAsString
robo-ont:metadataFormatAsString rdf:type owl:DatatypeProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/specificationKindAsString
robo-ont:specificationKindAsString rdf:type owl:DatatypeProperty .


###  https://www.cs7820-robo-orchestration.org/ontology/unitAsString
robo-ont:unitAsString rdf:type owl:DatatypeProperty .


#################################################################
#    Classes
#################################################################

###  https://www.cs7820-robo-orchestration.org/ontology/Action
robo-ont:Action rdf:type owl:Class ;
                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                  owl:onProperty [ owl:inverseOf robo-ont:enablesAction
                                                 ] ;
                                  owl:someValuesFrom robo-ont:Capability
                                ] .


###  https://www.cs7820-robo-orchestration.org/ontology/Agent
robo-ont:Agent rdf:type owl:Class ;
               rdfs:subClassOf robo-ont:SpatialThing ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty robo-ont:fulfillsArchetype ;
                                 owl:allValuesFrom robo-ont:Archetype
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty robo-ont:hasCapability ;
                                 owl:allValuesFrom robo-ont:Capability
                               ] .


###  https://www.cs7820-robo-orchestration.org/ontology/AgentCategory
robo-ont:AgentCategory rdf:type owl:Class ;
                       rdfs:subClassOf robo-ont:Category .


###  https://www.cs7820-robo-orchestration.org/ontology/Archetype
robo-ont:Archetype rdf:type owl:Class ;
                   rdfs:subClassOf [ rdf:type owl:Restriction ;
                                     owl:onProperty robo-ont:requiresCapability ;
                                     owl:someValuesFrom robo-ont:Capability
                                   ] ,
                                   [ rdf:type owl:Restriction ;
                                     owl:onProperty robo-ont:requiresCapability ;
                                     owl:allValuesFrom robo-ont:Capability
                                   ] .


###  https://www.cs7820-robo-orchestration.org/ontology/Audition
robo-ont:Audition rdf:type owl:Class ;
                  rdfs:subClassOf robo-ont:SensorBased .


###  https://www.cs7820-robo-orchestration.org/ontology/Capability
robo-ont:Capability rdf:type owl:Class ;
                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                      owl:onProperty robo-ont:hasSpec ;
                                      owl:someValuesFrom robo-ont:Specification
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty robo-ont:enabledBySpatialThing ;
                                      owl:allValuesFrom robo-ont:SpatialThing
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty robo-ont:enablesAction ;
                                      owl:allValuesFrom robo-ont:Action
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty robo-ont:hasSpec ;
                                      owl:allValuesFrom robo-ont:Specification
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty robo-ont:enabledBy ;
                                      owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                      owl:onClass robo-ont:SpatialThing
                                    ] .


###  https://www.cs7820-robo-orchestration.org/ontology/CargoBased
robo-ont:CargoBased rdf:type owl:Class ;
                    rdfs:subClassOf robo-ont:Capability .


###  https://www.cs7820-robo-orchestration.org/ontology/CategorizationType
robo-ont:CategorizationType rdf:type owl:Class .


###  https://www.cs7820-robo-orchestration.org/ontology/Category
robo-ont:Category rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty robo-ont:hasCategorizationType ;
                                    owl:someValuesFrom robo-ont:CategorizationType
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty robo-ont:hasCategorizationType ;
                                    owl:allValuesFrom robo-ont:CategorizationType
                                  ] .


###  https://www.cs7820-robo-orchestration.org/ontology/Close
robo-ont:Close rdf:type owl:Class ;
               rdfs:subClassOf robo-ont:GripperBased ;
               owl:disjointWith robo-ont:Open .


###  https://www.cs7820-robo-orchestration.org/ontology/ColdResistant
robo-ont:ColdResistant rdf:type owl:Class ;
                       rdfs:subClassOf robo-ont:ResistanceBased .


###  https://www.cs7820-robo-orchestration.org/ontology/Constructor
robo-ont:Constructor rdf:type owl:Class ;
                     rdfs:subClassOf robo-ont:Archetype .


###  https://www.cs7820-robo-orchestration.org/ontology/CorrosionResistant
robo-ont:CorrosionResistant rdf:type owl:Class ;
                            rdfs:subClassOf robo-ont:ResistanceBased .


###  https://www.cs7820-robo-orchestration.org/ontology/Digger
robo-ont:Digger rdf:type owl:Class ;
                rdfs:subClassOf robo-ont:Archetype .


###  https://www.cs7820-robo-orchestration.org/ontology/Distance
robo-ont:Distance rdf:type owl:Class ;
                  rdfs:subClassOf robo-ont:SensorBased .


###  https://www.cs7820-robo-orchestration.org/ontology/Environment
robo-ont:Environment rdf:type owl:Class ;
                     rdfs:subClassOf robo-ont:SpatialThing .


###  https://www.cs7820-robo-orchestration.org/ontology/EnvironmentCategory
robo-ont:EnvironmentCategory rdf:type owl:Class ;
                             rdfs:subClassOf robo-ont:Category .


###  https://www.cs7820-robo-orchestration.org/ontology/Explorer
robo-ont:Explorer rdf:type owl:Class ;
                  rdfs:subClassOf robo-ont:Archetype .


###  https://www.cs7820-robo-orchestration.org/ontology/Feature
robo-ont:Feature rdf:type owl:Class ;
                 rdfs:subClassOf robo-ont:SpatialThing ,
                                 [ rdf:type owl:Restriction ;
                                   owl:onProperty robo-ont:hasGeometry ;
                                   owl:allValuesFrom robo-ont:Geometry
                                 ] .


###  https://www.cs7820-robo-orchestration.org/ontology/Format
robo-ont:Format rdf:type owl:Class ;
                rdfs:subClassOf [ rdf:type owl:Restriction ;
                                  owl:onProperty robo-ont:metadataFormatAsString ;
                                  owl:allValuesFrom xsd:string
                                ] ,
                                [ rdf:type owl:Restriction ;
                                  owl:onProperty robo-ont:metadataFormatAsString ;
                                  owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                  owl:onDataRange xsd:string
                                ] .


###  https://www.cs7820-robo-orchestration.org/ontology/Geometry
robo-ont:Geometry rdf:type owl:Class ;
                  rdfs:subClassOf robo-ont:SpatialThing .


###  https://www.cs7820-robo-orchestration.org/ontology/Goal
robo-ont:Goal rdf:type owl:Class ;
              rdfs:subClassOf [ rdf:type owl:Restriction ;
                                owl:onProperty robo-ont:hasDeadline ;
                                owl:someValuesFrom robo-ont:TemporalExtent
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty robo-ont:hasTask ;
                                owl:someValuesFrom robo-ont:Task
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty robo-ont:hasSubGoal ;
                                owl:allValuesFrom robo-ont:Goal
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty robo-ont:hasTask ;
                                owl:allValuesFrom robo-ont:Task
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty robo-ont:hasDeadline ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass robo-ont:TemporalExtent
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty robo-ont:hasTask ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onClass robo-ont:Task
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty robo-ont:hasInstructionalText ;
                                owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                owl:onDataRange xsd:string
                              ] .


###  https://www.cs7820-robo-orchestration.org/ontology/GripperBased
robo-ont:GripperBased rdf:type owl:Class ;
                      rdfs:subClassOf robo-ont:Capability .


###  https://www.cs7820-robo-orchestration.org/ontology/Harvestor
robo-ont:Harvestor rdf:type owl:Class ;
                   rdfs:subClassOf robo-ont:Archetype .


###  https://www.cs7820-robo-orchestration.org/ontology/Hauler
robo-ont:Hauler rdf:type owl:Class ;
                rdfs:subClassOf robo-ont:Archetype .


###  https://www.cs7820-robo-orchestration.org/ontology/Identifier
robo-ont:Identifier rdf:type owl:Class ;
                    rdfs:subClassOf [ rdf:type owl:Restriction ;
                                      owl:onProperty robo-ont:identifierAsText ;
                                      owl:someValuesFrom xsd:string
                                    ] ,
                                    [ rdf:type owl:Restriction ;
                                      owl:onProperty robo-ont:identifierAsText ;
                                      owl:allValuesFrom xsd:string
                                    ] .


###  https://www.cs7820-robo-orchestration.org/ontology/Inspector
robo-ont:Inspector rdf:type owl:Class ;
                   rdfs:subClassOf robo-ont:Archetype .


###  https://www.cs7820-robo-orchestration.org/ontology/Location
robo-ont:Location rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty robo-ont:fileLocationAsString ;
                                    owl:allValuesFrom xsd:string
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty robo-ont:fileLocationAsString ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] .


###  https://www.cs7820-robo-orchestration.org/ontology/LowerThreshold
robo-ont:LowerThreshold rdf:type owl:Class ;
                        rdfs:subClassOf robo-ont:Threshold .


###  https://www.cs7820-robo-orchestration.org/ontology/Metadata
robo-ont:Metadata rdf:type owl:Class ;
                  rdfs:subClassOf [ rdf:type owl:Restriction ;
                                    owl:onProperty robo-ont:hasFileLocation ;
                                    owl:allValuesFrom robo-ont:Location
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty robo-ont:metadataFormat ;
                                    owl:allValuesFrom robo-ont:Format
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty robo-ont:hasFileLocation ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass robo-ont:Location
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty robo-ont:metadataFormat ;
                                    owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onClass robo-ont:Format
                                  ] ,
                                  [ rdf:type owl:Restriction ;
                                    owl:onProperty robo-ont:hasDescription ;
                                    owl:maxQualifiedCardinality "1"^^xsd:nonNegativeInteger ;
                                    owl:onDataRange xsd:string
                                  ] .


###  https://www.cs7820-robo-orchestration.org/ontology/MotionBased
robo-ont:MotionBased rdf:type owl:Class ;
                     rdfs:subClassOf robo-ont:Capability .


###  https://www.cs7820-robo-orchestration.org/ontology/Move
robo-ont:Move rdf:type owl:Class ;
              rdfs:subClassOf robo-ont:MotionBased .


###  https://www.cs7820-robo-orchestration.org/ontology/NominalThreshold
robo-ont:NominalThreshold rdf:type owl:Class ;
                          rdfs:subClassOf robo-ont:Threshold .


###  https://www.cs7820-robo-orchestration.org/ontology/Object
robo-ont:Object rdf:type owl:Class ;
                rdfs:subClassOf robo-ont:SpatialThing .


###  https://www.cs7820-robo-orchestration.org/ontology/ObjectCategory
robo-ont:ObjectCategory rdf:type owl:Class ;
                        rdfs:subClassOf robo-ont:Category .


###  https://www.cs7820-robo-orchestration.org/ontology/Open
robo-ont:Open rdf:type owl:Class ;
              rdfs:subClassOf robo-ont:GripperBased .


###  https://www.cs7820-robo-orchestration.org/ontology/Painter
robo-ont:Painter rdf:type owl:Class ;
                 rdfs:subClassOf robo-ont:Archetype .


###  https://www.cs7820-robo-orchestration.org/ontology/Pick
robo-ont:Pick rdf:type owl:Class ;
              rdfs:subClassOf robo-ont:GripperBased ;
              owl:disjointWith robo-ont:Place .


###  https://www.cs7820-robo-orchestration.org/ontology/Place
robo-ont:Place rdf:type owl:Class ;
               rdfs:subClassOf robo-ont:GripperBased .


###  https://www.cs7820-robo-orchestration.org/ontology/PowerBased
robo-ont:PowerBased rdf:type owl:Class ;
                    rdfs:subClassOf robo-ont:Capability .


###  https://www.cs7820-robo-orchestration.org/ontology/Press
robo-ont:Press rdf:type owl:Class ;
               rdfs:subClassOf robo-ont:MotionBased .


###  https://www.cs7820-robo-orchestration.org/ontology/Pull
robo-ont:Pull rdf:type owl:Class ;
              rdfs:subClassOf robo-ont:MotionBased ;
