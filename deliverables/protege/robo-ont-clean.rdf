    <!-- https://www.cs7820-robo-orchestration.org/ontology/Archetype -->

    <owl:Class rdf:about="https://www.cs7820-robo-orchestration.org/ontology/Archetype">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/requiresCapability"/>
                <owl:someValuesFrom rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/Capability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/requiresCapability"/>
                <owl:allValuesFrom rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/Capability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


