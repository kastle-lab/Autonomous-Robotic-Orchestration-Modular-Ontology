    <!-- https://www.cs7820-robo-orchestration.org/ontology/Action -->

    <owl:Class rdf:about="https://www.cs7820-robo-orchestration.org/ontology/Action">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty>
                    <rdf:Description>
                        <owl:inverseOf rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/enablesAction"/>
                    </rdf:Description>
                </owl:onProperty>
                <owl:someValuesFrom rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/Capability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- https://www.cs7820-robo-orchestration.org/ontology/Agent -->

    <owl:Class rdf:about="https://www.cs7820-robo-orchestration.org/ontology/Agent">
        <rdfs:subClassOf rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/SpatialThing"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/fulfillsArchetype"/>
                <owl:allValuesFrom rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/Archetype"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/hasCapability"/>
                <owl:allValuesFrom rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/Capability"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


