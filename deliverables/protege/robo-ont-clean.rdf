    <owl:Class rdf:about="https://www.cs7820-robo-orchestration.org/ontology/Audition">
        <rdfs:subClassOf rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/SensorBased"/>
    </owl:Class>
    


    <!-- https://www.cs7820-robo-orchestration.org/ontology/Capability -->

    <owl:Class rdf:about="https://www.cs7820-robo-orchestration.org/ontology/Capability">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/hasSpec"/>
                <owl:someValuesFrom rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/Specification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/enabledBySpatialThing"/>
                <owl:allValuesFrom rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/SpatialThing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/enablesAction"/>
                <owl:allValuesFrom rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/Action"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/hasSpec"/>
                <owl:allValuesFrom rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/Specification"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/enabledBy"/>
                <owl:qualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:qualifiedCardinality>
                <owl:onClass rdf:resource="https://www.cs7820-robo-orchestration.org/ontology/SpatialThing"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


